│      "oldString": "def _parse_agent_response_text(raw: Any) -> str:\n\t\"\"\"Extract assistant text from an agent_response.attrs.response value.\n\n\tThe response value is usually a JSON-encoded string representing an array\n\tof message objects with `parts`. This returns the concatenated text parts.\n\t\"\"\"\n\tif not raw:\n\t\treturn \"\"\n\ttry:\n\t\tobj = json.loads(raw) if isinstance(raw, str) else raw\n\t\ttexts: List[str] = []\n\t\tif isinstance(obj, list):\n\t\t\tfor msg in obj:\n\t\t\t\tparts = msg.get(\"parts\") if isinstance(msg, dict) else None\n\t\t\t\tif not parts:\n\t\t\t\t\tcontinue\n\t\t\t\tfor p in parts:\n\t\t\t\t\tif isinstance(p, dict) and p.get(\"type\") == \"text\":\n\t\t\t\t\t\ttexts.append(p.get(\"content\", \"\"))\n\t\treturn \"\\n\\n\".join(t for t in texts if t)\n\texcept Exception:\n\t\t# Fallback: return the raw string\n\t\treturn str(raw)",                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                │
│      "newString": "def _parse_agent_response_parts(raw: Any, outer_span_id: Optional[str] = None) -> tuple:\n\t\"\"\"Extract assistant text and tool calls from an agent_response.attrs.response value.\n\n\tThe response value is usually a JSON-encoded string representing an array\n\tof message objects with `parts`. Returns a tuple of (text: str, tool_calls: list[dict]).\n\tTool call dicts have keys: id, name, arguments, timestamp (None).\n\t\"\"\"\n\tif not raw:\n\t\treturn \"\", []\n\ttry:\n\t\tobj = json.loads(raw) if isinstance(raw, str) else raw\n\t\ttexts: List[str] = []\n\t\ttool_calls: List[dict] = []\n\t\tif isinstance(obj, list):\n\t\t\tfor msg in obj:\n\t\t\t\tparts = msg.get(\"parts\") if isinstance(msg, dict) else None\n\t\t\t\tif not parts:\n\t\t\t\t\tcontinue\n\t\t\t\tfor p in parts:\n\t\t\t\t\tif not isinstance(p, dict):\n\t\t\t\t\t\tcontinue\n\t\t\t\t\tif p.get(\"type\") == \"text\":\n\t\t\t\t\t\ttexts.append(p.get(\"content\", \"\"))\n\t\t\t\t\telif p.get(\"type\") == \"tool_call\":\n\t\t\t\t\t\tcall_id = p.get(\"id\") or outer_span_id or f\"call_{len(tool_calls)}\"\n\t\t\t\t\t\ttool_calls.append({\n\t\t\t\t\t\t\t\"id\": call_id,\n\t\t\t\t\t\t\t\"name\": p.get(\"name\", \"unknown\"),\n\t\t\t\t\t\t\t\"arguments\": _decode_args(p.get(\"arguments\", {})),\n\t\t\t\t\t\t\t\"timestamp\": None,\n\t\t\t\t\t\t})\n\t\treturn \"\\n\\n\".join(t for t in texts if t), tool_calls\n\texcept Exception:\n\t\t# Fallback: return the raw string with no tool calls\n\t\treturn str(raw), []" │
│    }                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                │
